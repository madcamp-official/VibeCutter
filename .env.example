# Local-only values for an authorized target. Copy to .env; never commit real values.
# P2 manifests may reference these names through command environments, but not secrets.
VIBECUTTER_TARGET_DB_PASSWORD=
VIBECUTTER_ROLE_A_TOKEN=
VIBECUTTER_ROLE_B_TOKEN=

# --- LLM endpoint (model/endpoints.py) -----------------------------------------
# primary = 외부 API 의 qwen3-235b(학습 안 함, 호출만), fallback = 기존 로컬 7B.
# 앞 tier 가 답을 못 주거나 timeout 이면 자동으로 다음 tier 로 넘어간다.
# 아래 값들은 전부 선택 — 비워두면 model/endpoints.py 의 기본값(내부망→외부망)을 쓴다.
VIBECUTTER_LLM_API_KEY=
# VIBECUTTER_LLM_ENDPOINTS=http://192.168.0.226:8080/v1,http://172.10.7.246:8080/v1
# VIBECUTTER_LLM_MODEL=qwen3-235b
# VIBECUTTER_LLM_TIMEOUT=600          # 7.7 tok/s → 긴 응답이 정상
# VIBECUTTER_LLM_MAX_TOKENS=512
# fallback(7B). 미설정이면 fallback 없이 primary 만 쓴다.
# VIBECUTTER_LLM_FALLBACK_ENDPOINT=http://127.0.0.1:8000/v1
# VIBECUTTER_LLM_FALLBACK_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
# VIBECUTTER_LLM_FALLBACK_TIMEOUT=60
# VIBECUTTER_LLM_DISABLE=1            # LLM 훅 끄고 휴리스틱만(CI/오프라인)
